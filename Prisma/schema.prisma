datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

generator client {
    provider             = "prisma-client-py"
    recursive_type_depth = 5
}

model Cliente_telenova {
    id           Int     @id @default(autoincrement())
    empresa_id   String
    cpf          String?
    cnpj         String?
    primeiroNome String

    telefone String

    // Garante que a mesma empresa não cadastre o mesmo contato duas vezes
    @@unique([empresa_id, cpf])
    @@unique([empresa_id, cnpj])
}
